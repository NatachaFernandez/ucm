
@prefix : <http://example.org/ucm#> .
@prefix sulo: <http://example.org/sulo#> .
@prefix ucm:  <http://example.org/ucm#> .
@prefix role: <http://example.org/role#> .
@prefix bfo:  <http://purl.obolibrary.org/obo/> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

#################################################################
# HIGH-LEVEL ALIGNMENT
#################################################################

ucm:PhysicalEntity a owl:Class ;
    rdfs:label "physical entity"@en ;
    rdfs:comment "A physical thing that occupies space and persists through time."@en ;
    rdfs:subClassOf sulo:SpatialObject , bfo:BFO_0000040 .

ucm:InformationalEntity a owl:Class ;
    rdfs:label "informational entity"@en ;
    rdfs:comment "An entity that conveys, records, classifies, or organizes content."@en ;
    rdfs:subClassOf sulo:InformationObject , bfo:BFO_0000031 .

ucm:Attribute a owl:Class ;
    rdfs:label "attribute"@en ;
    rdfs:comment "A dependent entity such as a role, disposition, or status borne by another entity."@en ;
    rdfs:subClassOf bfo:BFO_0000002 .

#################################################################
# CORE PROCESS HIERARCHY
#################################################################

ucm:CareProcess a owl:Class ;
    rdfs:label "care process"@en ;
    rdfs:comment "An occurrent in which actions are performed that directly influence the condition, functioning, or well-being of a subject."@en ;
    rdfs:subClassOf sulo:Process , bfo:BFO_0000015 .

ucm:AdministrativeProcess a owl:Class ;
    rdfs:label "administrative process"@en ;
    rdfs:comment "An occurrent in which activities govern, evaluate, enable, authorize, record, or account for other activities without directly altering a subject’s condition."@en ;
    rdfs:subClassOf sulo:Process , bfo:BFO_0000015 .

ucm:ObservationProcess a owl:Class ;
    rdfs:label "observation process"@en ;
    rdfs:comment "An occurrent in which information about an entity, attribute, or process is obtained or determined."@en ;
    rdfs:subClassOf sulo:Process , bfo:BFO_0000015 .

ucm:MeasurementProcess a owl:Class ;
    rdfs:label "measurement process"@en ;
    rdfs:comment "An observation process in which a quantitative result is determined."@en ;
    rdfs:subClassOf ucm:ObservationProcess .

ucm:AssessmentProcess a owl:Class ;
    rdfs:label "assessment process"@en ;
    rdfs:comment "An observation process in which a qualitative or interpretive result is determined."@en ;
    rdfs:subClassOf ucm:ObservationProcess .

ucm:Procedure a owl:Class ;
    rdfs:label "procedure"@en ;
    rdfs:comment "An occurrent in which diagnostic, therapeutic, preventive, or otherwise clinically relevant actions are performed."@en ;
    rdfs:subClassOf ucm:CareProcess .

#################################################################
# PHYSICAL ENTITIES
#################################################################

ucm:Person a owl:Class ;
    rdfs:label "person"@en ;
    rdfs:comment "A human being that may bear roles, attributes, and conditions and may participate in occurrents."@en ;
    rdfs:subClassOf ucm:PhysicalEntity .

ucm:Material a owl:Class ;
    rdfs:label "material"@en ;
    rdfs:comment "A physical entity that may be used, delivered, consumed, allocated, or observed."@en ;
    rdfs:subClassOf ucm:PhysicalEntity .

ucm:HousingUnit a owl:Class ;
    rdfs:label "housing unit"@en ;
    rdfs:comment "A physical structure that may serve as a dwelling."@en ;
    rdfs:subClassOf ucm:Material .

ucm:SubstanceExposureAgent a owl:Class ;
    rdfs:label "substance exposure agent"@en ;
    rdfs:comment "A physical substance or product whose presence may trigger an adverse response."@en ;
    rdfs:subClassOf ucm:Material .

#################################################################
# INFORMATION OBJECTS / CLASSIFICATION LAYER
#################################################################

ucm:CareDomain a owl:Class ;
    rdfs:label "care domain"@en ;
    rdfs:comment "A classification indicating the institutional or organizational context in which activities occur."@en ;
    rdfs:subClassOf ucm:InformationalEntity .

ucm:ClinicalCare a owl:Class ;
    rdfs:label "clinical care"@en ;
    rdfs:comment "A context involving diagnosis, treatment, or management of physiological or pathological situations."@en ;
    rdfs:subClassOf ucm:CareDomain .

ucm:SocialCare a owl:Class ;
    rdfs:label "social care"@en ;
    rdfs:comment "A context involving response to social or environmental circumstances affecting well-being."@en ;
    rdfs:subClassOf ucm:CareDomain .

ucm:PublicHealthCare a owl:Class ;
    rdfs:label "public health care"@en ;
    rdfs:comment "A context involving population-level prevention, surveillance, or health promotion."@en ;
    rdfs:subClassOf ucm:CareDomain .

ucm:CareFocus a owl:Class ;
    rdfs:label "care focus"@en ;
    rdfs:comment "A classification describing the type of need, problem, concern, or situation toward which activity is directed."@en ;
    rdfs:subClassOf ucm:InformationalEntity .

ucm:HealthFocus a owl:Class ;
    rdfs:label "health focus"@en ;
    rdfs:comment "A classification for concerns related to physiological or pathological functioning."@en ;
    rdfs:subClassOf ucm:CareFocus .

ucm:BehavioralFocus a owl:Class ;
    rdfs:label "behavioral focus"@en ;
    rdfs:comment "A classification for concerns related to mental, emotional, or behavioral functioning."@en ;
    rdfs:subClassOf ucm:CareFocus .

ucm:SocialNeed a owl:Class ;
    rdfs:label "social need"@en ;
    rdfs:comment "A classification for concerns arising from social or environmental circumstances."@en ;
    rdfs:subClassOf ucm:CareFocus .

ucm:HousingInstability a owl:Class ;
    rdfs:label "housing instability"@en ;
    rdfs:comment "A classification for circumstances in which stable or adequate shelter is lacking or uncertain."@en ;
    rdfs:subClassOf ucm:SocialNeed .

ucm:InterventionType a owl:Class ;
    rdfs:label "intervention type"@en ;
    rdfs:comment "A classification describing the manner in which actions are carried out."@en ;
    rdfs:subClassOf ucm:InformationalEntity .

ucm:Provision a owl:Class ;
    rdfs:label "provision"@en ;
    rdfs:comment "A classification for approaches involving making goods or services available."@en ;
    rdfs:subClassOf ucm:InterventionType .

ucm:Counseling a owl:Class ;
    rdfs:label "counseling"@en ;
    rdfs:comment "A classification for approaches involving guidance or communication intended to influence understanding or behavior."@en ;
    rdfs:subClassOf ucm:InterventionType .

ucm:CareCoordination a owl:Class ;
    rdfs:label "care coordination"@en ;
    rdfs:comment "A classification for approaches involving organization and alignment of multiple activities or actors."@en ;
    rdfs:subClassOf ucm:InterventionType .

ucm:Program a owl:Class ;
    rdfs:label "program"@en ;
    rdfs:comment "An organized set of rules, services, and resources under a governing framework."@en ;
    rdfs:subClassOf ucm:InformationalEntity .

ucm:ServiceSpecification a owl:Class ;
    rdfs:label "service specification"@en ;
    rdfs:comment "An information entity describing a type of activity that may be requested, approved, or carried out."@en ;
    rdfs:subClassOf ucm:InformationalEntity .

ucm:CarePlan a owl:Class ;
    rdfs:label "care plan"@en ;
    rdfs:comment "An information entity describing intended actions, goals, or arrangements."@en ;
    rdfs:subClassOf ucm:InformationalEntity .

#################################################################
# CONDITIONS / CLINICAL-SOCIAL SITUATIONS
#################################################################

ucm:Condition a owl:Class ;
    rdfs:label "condition"@en ;
    rdfs:comment "A state, situation, or circumstance associated with a subject that may be relevant for intervention, evaluation, or care."@en ;
    rdfs:subClassOf sulo:Object .

ucm:HealthCondition a owl:Class ;
    rdfs:label "health condition"@en ;
    rdfs:comment "A condition related to physiological or pathological functioning."@en ;
    rdfs:subClassOf ucm:Condition .

ucm:BehavioralCondition a owl:Class ;
    rdfs:label "behavioral condition"@en ;
    rdfs:comment "A condition related to behavior, mental processes, or substance use."@en ;
    rdfs:subClassOf ucm:Condition .

ucm:SocialCondition a owl:Class ;
    rdfs:label "social condition"@en ;
    rdfs:comment "A condition arising from social or environmental circumstances."@en ;
    rdfs:subClassOf ucm:Condition .

ucm:DispositionalCondition a owl:Class ;
    rdfs:label "dispositional condition"@en ;
    rdfs:comment "A condition consisting in a tendency, susceptibility, or risk that may be realized under certain circumstances."@en ;
    rdfs:subClassOf ucm:Condition , bfo:BFO_0000016 .

ucm:AllergyIntolerance a owl:Class ;
    rdfs:label "allergy intolerance"@en ;
    rdfs:comment "A dispositional condition involving risk of adverse response upon exposure to a substance, product, or class."@en ;
    rdfs:subClassOf ucm:HealthCondition , ucm:DispositionalCondition .

#################################################################
# CLINICAL / EVALUATIVE QUALIFIERS
#################################################################

ucm:ClinicalStatus a owl:Class ;
    rdfs:label "clinical status"@en ;
    rdfs:comment "An information entity representing current standing."@en ;
    rdfs:subClassOf ucm:InformationalEntity .

ucm:VerificationStatus a owl:Class ;
    rdfs:label "verification status"@en ;
    rdfs:comment "An information entity representing degree of confirmation."@en ;
    rdfs:subClassOf ucm:InformationalEntity .

ucm:Severity a owl:Class ;
    rdfs:label "severity"@en ;
    rdfs:comment "An information entity representing degree of seriousness or intensity."@en ;
    rdfs:subClassOf ucm:InformationalEntity .

ucm:EnrollmentStatus a owl:Class ;
    rdfs:label "enrollment status"@en ;
    rdfs:comment "An information entity representing formal association with a governed context."@en ;
    rdfs:subClassOf ucm:InformationalEntity .

ucm:AuthorizationDecision a owl:Class ;
    rdfs:label "authorization decision"@en ;
    rdfs:comment "An information entity representing the outcome of a permission evaluation."@en ;
    rdfs:subClassOf ucm:InformationalEntity .

#################################################################
# STATEMENTS / REPORTS / COLLECTIONS
#################################################################

ucm:Collection a owl:Class ;
    rdfs:label "collection"@en ;
    rdfs:comment "An information entity consisting of zero or more members."@en ;
    rdfs:subClassOf sulo:Collection .

ucm:Statement a owl:Class ;
    rdfs:label "statement"@en ;
    rdfs:comment "An information entity asserting or recording something about an entity, attribute, or occurrent."@en ;
    rdfs:subClassOf ucm:InformationalEntity .

ucm:ClinicalStatement a owl:Class ;
    rdfs:label "clinical statement"@en ;
    rdfs:comment "A statement recording a clinically relevant situation."@en ;
    rdfs:subClassOf ucm:Statement .

ucm:ObservationStatement a owl:Class ;
    rdfs:label "observation statement"@en ;
    rdfs:comment "A statement representing the result of an observation process."@en ;
    rdfs:subClassOf ucm:Statement .

ucm:Report a owl:Class ;
    rdfs:label "report"@en ;
    rdfs:comment "An information entity composed of multiple organized statements for communication or record-keeping."@en ;
    rdfs:subClassOf ucm:Collection , ucm:InformationalEntity .

ucm:ReactionManifestation a owl:Class ;
    rdfs:label "reaction manifestation"@en ;
    rdfs:comment "An information entity representing an observed sign or symptom of adverse response."@en ;
    rdfs:subClassOf ucm:InformationalEntity .

#################################################################
# PARTICIPATION / ROLES
#################################################################

ucm:Participation a owl:Class ;
    rdfs:label "participation"@en ;
    rdfs:comment "An information entity representing involvement of an entity in an occurrent together with contextual details."@en ;
    rdfs:subClassOf ucm:InformationalEntity .

ucm:ActorRole a owl:Class ;
    rdfs:label "actor role"@en ;
    rdfs:comment "A realizable entity specifying a capacity assumed by an entity in a context."@en ;
    rdfs:subClassOf bfo:BFO_0000023 .

role:BeneficiaryRole a owl:Class ;
    rdfs:label "beneficiary role"@en ;
    rdfs:comment "A capacity associated with receiving intended benefit."@en ;
    rdfs:subClassOf ucm:ActorRole .

ucm:ProviderRole a owl:Class ;
    rdfs:label "provider role"@en ;
    rdfs:comment "A capacity associated with performing actions."@en ;
    rdfs:subClassOf ucm:ActorRole .

ucm:PayerRole a owl:Class ;
    rdfs:label "payer role"@en ;
    rdfs:comment "A capacity associated with financing activities."@en ;
    rdfs:subClassOf ucm:ActorRole .

ucm:RequesterRole a owl:Class ;
    rdfs:label "requester role"@en ;
    rdfs:comment "A capacity associated with initiating actions."@en ;
    rdfs:subClassOf ucm:ActorRole .

#################################################################
# CARE PROCESS SUBTYPES
#################################################################

ucm:ProvisioningProcess a owl:Class ;
    rdfs:label "provisioning process"@en ;
    rdfs:comment "An occurrent in which something is made available to a recipient."@en ;
    rdfs:subClassOf ucm:CareProcess ,
        [ a owl:Restriction ;
          owl:onProperty ucm:hasBeneficiary ;
          owl:someValuesFrom ucm:PhysicalEntity ],
        [ a owl:Restriction ;
          owl:onProperty ucm:providesResource ;
          owl:someValuesFrom ucm:PhysicalEntity ] .

ucm:AssignmentProcess a owl:Class ;
    rdfs:label "assignment process"@en ;
    rdfs:comment "An occurrent in which an entity is designated or allocated within a context."@en ;
    rdfs:subClassOf ucm:CareProcess ,
        [ a owl:Restriction ;
          owl:onProperty ucm:assignsEntity ;
          owl:someValuesFrom ucm:PhysicalEntity ] .

ucm:RoleAssignmentProcess a owl:Class ;
    rdfs:label "role assignment process"@en ;
    rdfs:comment "An occurrent in which an entity is designated to bear a role."@en ;
    rdfs:subClassOf ucm:AssignmentProcess ,
        [ a owl:Restriction ;
          owl:onProperty ucm:assignsRole ;
          owl:someValuesFrom ucm:ActorRole ] .

ucm:ResourceAssignmentProcess a owl:Class ;
    rdfs:label "resource assignment process"@en ;
    rdfs:comment "An occurrent in which an entity is allocated to a resource to use or occupy."@en ;
    rdfs:subClassOf ucm:AssignmentProcess ,
        [ a owl:Restriction ;
          owl:onProperty ucm:assignsResource ;
          owl:someValuesFrom ucm:PhysicalEntity ] .

ucm:ProvisioningProcess owl:disjointWith ucm:AssignmentProcess .

#################################################################
# ADMINISTRATIVE PROCESS SUBTYPES
#################################################################

ucm:EligibilityDisposition a owl:Class ;
    rdfs:label "eligibility disposition"@en ;
    rdfs:comment "A realizable property indicating qualification under defined conditions."@en ;
    rdfs:subClassOf bfo:BFO_0000016 .

ucm:EligibilityDeterminationProcess a owl:Class ;
    rdfs:label "eligibility determination process"@en ;
    rdfs:comment "An occurrent in which qualification is evaluated against defined criteria."@en ;
    rdfs:subClassOf ucm:AdministrativeProcess ,
        [ a owl:Restriction ;
          owl:onProperty ucm:hasEligibilitySubject ;
          owl:someValuesFrom ucm:PhysicalEntity ],
        [ a owl:Restriction ;
          owl:onProperty ucm:determinesEligibilityFor ;
          owl:someValuesFrom owl:Thing ] .

ucm:EnrollmentProcess a owl:Class ;
    rdfs:label "enrollment process"@en ;
    rdfs:comment "An occurrent in which an entity becomes formally associated with a governed context."@en ;
    rdfs:subClassOf ucm:AdministrativeProcess ,
        [ a owl:Restriction ;
          owl:onProperty ucm:hasEnrollmentSubject ;
          owl:someValuesFrom ucm:PhysicalEntity ],
        [ a owl:Restriction ;
          owl:onProperty ucm:enrollsInProgram ;
          owl:someValuesFrom ucm:Program ] .

ucm:AuthorizationProcess a owl:Class ;
    rdfs:label "authorization process"@en ;
    rdfs:comment "An occurrent in which permission is granted, denied, or constrained for a specific activity."@en ;
    rdfs:subClassOf ucm:AdministrativeProcess ,
        [ a owl:Restriction ;
          owl:onProperty ucm:hasAuthorizationSubject ;
          owl:someValuesFrom ucm:PhysicalEntity ],
        [ a owl:Restriction ;
          owl:onProperty ucm:resultsInAuthorizationDecision ;
          owl:someValuesFrom ucm:AuthorizationDecision ] .

ucm:PaymentProcess a owl:Class ;
    rdfs:label "payment process"@en ;
    rdfs:comment "An occurrent in which financial value is transferred in relation to activities."@en ;
    rdfs:subClassOf ucm:AdministrativeProcess .

ucm:AdjudicationProcess a owl:Class ;
    rdfs:label "adjudication process"@en ;
    rdfs:comment "An occurrent in which submitted claims or requests are evaluated and resolved according to governing rules."@en ;
    rdfs:subClassOf ucm:AdministrativeProcess .

ucm:EligibilityDeterminationProcess owl:disjointWith ucm:EnrollmentProcess .
ucm:EligibilityDeterminationProcess owl:disjointWith ucm:AuthorizationProcess .
ucm:EnrollmentProcess owl:disjointWith ucm:AuthorizationProcess .

#################################################################
# REACTION / EVENT SUBMODEL
#################################################################

ucm:AdverseReactionEvent a owl:Class ;
    rdfs:label "adverse reaction event"@en ;
    rdfs:comment "An occurrent in which exposure results in an adverse response."@en ;
    rdfs:subClassOf sulo:Process , bfo:BFO_0000015 .

#################################################################
# OBJECT PROPERTIES — CORE CARE
#################################################################

ucm:hasDomain a owl:ObjectProperty ;
    rdfs:label "has domain"@en ;
    rdfs:comment "Relates an occurrent to the context in which it takes place."@en ;
    rdfs:domain ucm:CareProcess ;
    rdfs:range ucm:CareDomain .

ucm:hasFocus a owl:ObjectProperty ;
    rdfs:label "has focus"@en ;
    rdfs:comment "Relates an occurrent to the type of need, problem, or concern toward which it is directed."@en ;
    rdfs:domain ucm:CareProcess ;
    rdfs:range ucm:CareFocus .

ucm:hasInterventionType a owl:ObjectProperty ;
    rdfs:label "has intervention type"@en ;
    rdfs:comment "Relates an occurrent to the manner in which actions are performed."@en ;
    rdfs:domain ucm:CareProcess ;
    rdfs:range ucm:InterventionType .

ucm:realizesPlan a owl:ObjectProperty ;
    rdfs:label "realizes plan"@en ;
    rdfs:comment "Relates an occurrent to an information entity describing intended actions it carries out."@en ;
    rdfs:domain sulo:Process ;
    rdfs:range ucm:CarePlan .

#################################################################
# OBJECT PROPERTIES — PROCESS STRUCTURE
#################################################################

ucm:hasPhase a owl:ObjectProperty ;
    rdfs:label "has phase"@en ;
    rdfs:comment "Relates an occurrent to a temporally bounded part contributing to its execution."@en ;
    rdfs:domain sulo:Process ;
    rdfs:range sulo:Process .

ucm:hasTrigger a owl:ObjectProperty ;
    rdfs:label "has trigger"@en ;
    rdfs:comment "Relates an occurrent to another occurrent that initiates it."@en ;
    rdfs:domain sulo:Process ;
    rdfs:range sulo:Process .

ucm:hasInput a owl:ObjectProperty ;
    rdfs:label "has input"@en ;
    rdfs:comment "Relates an occurrent to something used or transformed during execution."@en ;
    rdfs:domain sulo:Process ;
    rdfs:range sulo:Object .

ucm:hasOutput a owl:ObjectProperty ;
    rdfs:label "has output"@en ;
    rdfs:comment "Relates an occurrent to something produced as a result."@en ;
    rdfs:domain sulo:Process ;
    rdfs:range sulo:Object .

ucm:hasOutcome a owl:ObjectProperty ;
    rdfs:label "has outcome"@en ;
    rdfs:comment "Relates an occurrent to a resulting state, result, or evaluative finding."@en ;
    rdfs:domain sulo:Process ;
    rdfs:range ucm:InformationalEntity .

#################################################################
# OBJECT PROPERTIES — PARTICIPATION / ROLE
#################################################################

ucm:hasParticipant a owl:ObjectProperty ;
    rdfs:label "has participant"@en ;
    rdfs:comment "Relates a participation record to an entity involved in an occurrent."@en ;
    rdfs:subPropertyOf sulo:hasParticipant ;
    rdfs:domain ucm:Participation ;
    rdfs:range ucm:PhysicalEntity .

ucm:inProcess a owl:ObjectProperty ;
    rdfs:label "in process"@en ;
    rdfs:comment "Relates a participation record to the occurrent in which involvement occurs."@en ;
    rdfs:domain ucm:Participation ;
    rdfs:range sulo:Process .

ucm:hasRole a owl:ObjectProperty ;
    rdfs:label "has role"@en ;
    rdfs:comment "Relates a participation record to the capacity in which involvement occurs."@en ;
    rdfs:domain ucm:Participation ;
    rdfs:range ucm:ActorRole .

#################################################################
# OBJECT PROPERTIES — PROVISIONING / ASSIGNMENT
#################################################################

ucm:hasBeneficiary a owl:ObjectProperty ;
    rdfs:label "has beneficiary"@en ;
    rdfs:comment "Relates an occurrent to an entity that receives intended benefit."@en ;
    rdfs:domain sulo:Process ;
    rdfs:range ucm:PhysicalEntity .

ucm:providesResource a owl:ObjectProperty ;
    rdfs:label "provides resource"@en ;
    rdfs:comment "Relates an occurrent to something made available or delivered."@en ;
    rdfs:domain sulo:Process ;
    rdfs:range ucm:PhysicalEntity .

ucm:assignsEntity a owl:ObjectProperty ;
    rdfs:label "assigns entity"@en ;
    rdfs:comment "Relates an occurrent to something designated or allocated."@en ;
    rdfs:domain sulo:Process ;
    rdfs:range ucm:PhysicalEntity .

ucm:assignsRole a owl:ObjectProperty ;
    rdfs:label "assigns role"@en ;
    rdfs:comment "Relates an occurrent to a role that is conferred or designated."@en ;
    rdfs:domain sulo:Process ;
    rdfs:range ucm:ActorRole .

ucm:assignsResource a owl:ObjectProperty ;
    rdfs:label "assigns resource"@en ;
    rdfs:comment "Relates an occurrent to something allocated without necessarily transferring access or possession."@en ;
    rdfs:domain sulo:Process ;
    rdfs:range ucm:PhysicalEntity .

#################################################################
# OBJECT PROPERTIES — ADMINISTRATIVE
#################################################################

ucm:hasEligibilityDisposition a owl:ObjectProperty ;
    rdfs:label "has eligibility disposition"@en ;
    rdfs:comment "Relates an entity to a realizable property indicating qualification."@en ;
    rdfs:domain ucm:PhysicalEntity ;
    rdfs:range ucm:EligibilityDisposition .

ucm:hasEligibilitySubject a owl:ObjectProperty ;
    rdfs:label "has eligibility subject"@en ;
    rdfs:comment "Relates an occurrent to the entity whose qualification is being evaluated."@en ;
    rdfs:domain ucm:EligibilityDeterminationProcess ;
    rdfs:range ucm:PhysicalEntity .

ucm:determinesEligibilityFor a owl:ObjectProperty ;
    rdfs:label "determines eligibility for"@en ;
    rdfs:comment "Relates an occurrent to the governed context, activity, or specification against which qualification is evaluated."@en ;
    rdfs:domain ucm:EligibilityDeterminationProcess ;
    rdfs:range owl:Thing .

ucm:resultsInEligibilityDisposition a owl:ObjectProperty ;
    rdfs:label "results in eligibility disposition"@en ;
    rdfs:comment "Relates an occurrent to the realizable property it establishes or confirms."@en ;
    rdfs:domain ucm:EligibilityDeterminationProcess ;
    rdfs:range ucm:EligibilityDisposition .

ucm:hasEnrollmentSubject a owl:ObjectProperty ;
    rdfs:label "has enrollment subject"@en ;
    rdfs:comment "Relates an occurrent to the entity becoming formally associated with a governed context."@en ;
    rdfs:domain ucm:EnrollmentProcess ;
    rdfs:range ucm:PhysicalEntity .

ucm:enrollsInProgram a owl:ObjectProperty ;
    rdfs:label "enrolls in program"@en ;
    rdfs:comment "Relates an occurrent to the governed context into which formal association is established."@en ;
    rdfs:domain ucm:EnrollmentProcess ;
    rdfs:range ucm:Program .

ucm:resultsInEnrollmentStatus a owl:ObjectProperty ;
    rdfs:label "results in enrollment status"@en ;
    rdfs:comment "Relates an occurrent to the information entity recording formal association."@en ;
    rdfs:domain ucm:EnrollmentProcess ;
    rdfs:range ucm:EnrollmentStatus .

ucm:isEnrolledIn a owl:ObjectProperty ;
    rdfs:label "is enrolled in"@en ;
    rdfs:comment "Relates an entity to a governed context with which it is formally associated."@en ;
    rdfs:domain ucm:PhysicalEntity ;
    rdfs:range ucm:Program .

ucm:hasAuthorizationSubject a owl:ObjectProperty ;
    rdfs:label "has authorization subject"@en ;
    rdfs:comment "Relates an occurrent to the entity for whom permission is being evaluated."@en ;
    rdfs:domain ucm:AuthorizationProcess ;
    rdfs:range ucm:PhysicalEntity .

ucm:authorizesProcess a owl:ObjectProperty ;
    rdfs:label "authorizes process"@en ;
    rdfs:comment "Relates an occurrent to the activity whose performance is being permitted, denied, or constrained."@en ;
    rdfs:domain ucm:AuthorizationProcess ;
    rdfs:range ucm:CareProcess .

ucm:authorizesServiceSpecification a owl:ObjectProperty ;
    rdfs:label "authorizes service specification"@en ;
    rdfs:comment "Relates an occurrent to the specification describing the kind of activity under permission evaluation."@en ;
    rdfs:domain ucm:AuthorizationProcess ;
    rdfs:range ucm:ServiceSpecification .

ucm:resultsInAuthorizationDecision a owl:ObjectProperty ;
    rdfs:label "results in authorization decision"@en ;
    rdfs:comment "Relates an occurrent to the information entity recording the outcome of a permission evaluation."@en ;
    rdfs:domain ucm:AuthorizationProcess ;
    rdfs:range ucm:AuthorizationDecision .

ucm:enablesProcess a owl:ObjectProperty ;
    rdfs:label "enables process"@en ;
    rdfs:comment "Relates an occurrent that allows, governs, or permits another to occur."@en ;
    rdfs:domain ucm:AdministrativeProcess ;
    rdfs:range ucm:CareProcess .

ucm:hasAdministrativePrecondition a owl:ObjectProperty ;
    rdfs:label "has administrative precondition"@en ;
    rdfs:comment "Relates an occurrent to another that must occur before it can proceed."@en ;
    rdfs:domain ucm:CareProcess ;
    rdfs:range ucm:AdministrativeProcess .

ucm:governsProgram a owl:ObjectProperty ;
    rdfs:label "governs program"@en ;
    rdfs:comment "Relates an occurrent to the governed context within which it operates."@en ;
    rdfs:domain ucm:AdministrativeProcess ;
    rdfs:range ucm:Program .

ucm:paysFor a owl:ObjectProperty ;
    rdfs:label "pays for"@en ;
    rdfs:comment "Relates an occurrent involving financial transfer to an activity for which value is transferred."@en ;
    rdfs:domain ucm:PaymentProcess ;
    rdfs:range ucm:CareProcess .

ucm:precedesAdministrativeProcess a owl:ObjectProperty ;
    rdfs:label "precedes administrative process"@en ;
    rdfs:comment "Relates one governing occurrent to another that typically follows it in a workflow."@en ;
    rdfs:domain ucm:AdministrativeProcess ;
    rdfs:range ucm:AdministrativeProcess .

ucm:hasBasisInEligibility a owl:ObjectProperty ;
    rdfs:label "has basis in eligibility"@en ;
    rdfs:comment "Relates an occurrent to a prior qualification evaluation or qualification-bearing attribute on which it depends."@en ;
    rdfs:domain ucm:AdministrativeProcess ;
    rdfs:range owl:Thing .

#################################################################
# OBJECT PROPERTIES — CONDITIONS / CLINICAL
#################################################################

ucm:hasCondition a owl:ObjectProperty ;
    rdfs:label "has condition"@en ;
    rdfs:comment "Relates a subject to a state, situation, or circumstance associated with it."@en ;
    rdfs:domain ucm:Person ;
    rdfs:range ucm:Condition .

ucm:hasAllergyIntolerance a owl:ObjectProperty ;
    rdfs:label "has allergy intolerance"@en ;
    rdfs:comment "Relates a subject to a susceptibility for adverse response associated with exposure."@en ;
    rdfs:domain ucm:Person ;
    rdfs:range ucm:AllergyIntolerance ;
    rdfs:subPropertyOf ucm:hasCondition .

ucm:instanceOfFocus a owl:ObjectProperty ;
    rdfs:label "instance of focus"@en ;
    rdfs:comment "Relates a condition to the classification it exemplifies."@en ;
    rdfs:domain ucm:Condition ;
    rdfs:range ucm:CareFocus .

ucm:addressesCondition a owl:ObjectProperty ;
    rdfs:label "addresses condition"@en ;
    rdfs:comment "Relates an occurrent to a condition it is intended to manage, monitor, treat, prevent, or otherwise influence."@en ;
    rdfs:domain ucm:CareProcess ;
    rdfs:range ucm:Condition .

ucm:targetsFocus a owl:ObjectProperty ;
    rdfs:label "targets focus"@en ;
    rdfs:comment "Relates an occurrent to the classification of concern toward which it is directed."@en ;
    rdfs:domain ucm:CareProcess ;
    rdfs:range ucm:CareFocus .

ucm:hasClinicalStatus a owl:ObjectProperty ;
    rdfs:label "has clinical status"@en ;
    rdfs:comment "Relates a condition to its current standing."@en ;
    rdfs:domain ucm:Condition ;
    rdfs:range ucm:ClinicalStatus .

ucm:hasVerificationStatus a owl:ObjectProperty ;
    rdfs:label "has verification status"@en ;
    rdfs:comment "Relates a condition to its degree of confirmation."@en ;
    rdfs:domain ucm:Condition ;
    rdfs:range ucm:VerificationStatus .

ucm:hasSeverity a owl:ObjectProperty ;
    rdfs:label "has severity"@en ;
    rdfs:comment "Relates a condition, statement, or reaction evidence to degree of seriousness."@en ;
    rdfs:domain sulo:Object ;
    rdfs:range ucm:Severity .

ucm:hasOnset a owl:ObjectProperty ;
    rdfs:label "has onset"@en ;
    rdfs:comment "Relates a condition to an information entity marking when it began or was first recognized."@en ;
    rdfs:domain ucm:Condition ;
    rdfs:range ucm:InformationalEntity .

ucm:hasAbatement a owl:ObjectProperty ;
    rdfs:label "has abatement"@en ;
    rdfs:comment "Relates a condition to an information entity marking when it ended or became inactive."@en ;
    rdfs:domain ucm:Condition ;
    rdfs:range ucm:InformationalEntity .

#################################################################
# OBJECT PROPERTIES — OBSERVATION / STATEMENT / REPORT
#################################################################

ucm:producesStatement a owl:ObjectProperty ;
    rdfs:label "produces statement"@en ;
    rdfs:comment "Relates an observation process to the statement it produces."@en ;
    rdfs:domain ucm:ObservationProcess ;
    rdfs:range ucm:ObservationStatement .

ucm:hasOutputStatement a owl:ObjectProperty ;
    rdfs:label "has output statement"@en ;
    rdfs:comment "Relates an occurrent to a statement generated as an output."@en ;
    rdfs:domain sulo:Process ;
    rdfs:range ucm:Statement .

ucm:aboutEntity a owl:ObjectProperty ;
    rdfs:label "about entity"@en ;
    rdfs:comment "Relates a statement to an entity it concerns."@en ;
    rdfs:domain ucm:Statement ;
    rdfs:range sulo:Object .

ucm:aboutProcess a owl:ObjectProperty ;
    rdfs:label "about process"@en ;
    rdfs:comment "Relates a statement to an occurrent it concerns."@en ;
    rdfs:domain ucm:Statement ;
    rdfs:range sulo:Process .

ucm:hasValue a owl:ObjectProperty ;
    rdfs:label "has value"@en ;
    rdfs:comment "Relates an observation statement to the informational value it conveys."@en ;
    rdfs:domain ucm:ObservationStatement ;
    rdfs:range ucm:InformationalEntity .

ucm:hasUnit a owl:ObjectProperty ;
    rdfs:label "has unit"@en ;
    rdfs:comment "Relates a statement to a unit of measure."@en ;
    rdfs:domain ucm:ObservationStatement ;
    rdfs:range ucm:InformationalEntity .

ucm:assertsCondition a owl:ObjectProperty ;
    rdfs:label "asserts condition"@en ;
    rdfs:comment "Relates a statement to a condition it records or asserts."@en ;
    rdfs:domain ucm:ClinicalStatement ;
    rdfs:range ucm:Condition .

ucm:hasMember a owl:ObjectProperty ;
    rdfs:label "has member"@en ;
    rdfs:comment "Relates a collection to an item it contains."@en ;
    rdfs:domain ucm:Collection ;
    rdfs:range owl:Thing .

ucm:hasStatement a owl:ObjectProperty ;
    rdfs:label "has statement"@en ;
    rdfs:comment "Relates a report to a statement it contains."@en ;
    rdfs:domain ucm:Report ;
    rdfs:range ucm:Statement .

ucm:documentsProcess a owl:ObjectProperty ;
    rdfs:label "documents process"@en ;
    rdfs:comment "Relates a report to an occurrent it documents."@en ;
    rdfs:domain ucm:Report ;
    rdfs:range sulo:Process .

#################################################################
# OBJECT PROPERTIES — MATERIALS / REACTIONS
#################################################################

ucm:usesMaterial a owl:ObjectProperty ;
    rdfs:label "uses material"@en ;
    rdfs:comment "Relates an occurrent to a physical entity employed during execution."@en ;
    rdfs:domain ucm:CareProcess ;
    rdfs:range ucm:Material .

ucm:hasCausativeAgent a owl:ObjectProperty ;
    rdfs:label "has causative agent"@en ;
    rdfs:comment "Relates a susceptibility for adverse response to the substance or product that may realize it."@en ;
    rdfs:domain ucm:AllergyIntolerance ;
    rdfs:range ucm:SubstanceExposureAgent .

ucm:hasManifestation a owl:ObjectProperty ;
    rdfs:label "has manifestation"@en ;
    rdfs:comment "Relates reaction evidence to an observed sign or symptom."@en ;
    rdfs:domain ucm:InformationalEntity ;
    rdfs:range ucm:ReactionManifestation .

ucm:realizesDisposition a owl:ObjectProperty ;
    rdfs:label "realizes disposition"@en ;
    rdfs:comment "Relates an occurrent to a susceptibility that becomes manifest through it."@en ;
    rdfs:domain sulo:Process ;
    rdfs:range ucm:DispositionalCondition .

ucm:hasReactionEvent a owl:ObjectProperty ;
    rdfs:label "has reaction event"@en ;
    rdfs:comment "Relates a susceptibility for adverse response to an occurrent that provides evidence of its realization."@en ;
    rdfs:domain ucm:AllergyIntolerance ;
    rdfs:range ucm:AdverseReactionEvent .

#################################################################
# USEFUL CONSTRAINTS
#################################################################

ucm:AllergyIntolerance rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ucm:hasCausativeAgent ;
      owl:someValuesFrom ucm:SubstanceExposureAgent ] .

ucm:Procedure rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ucm:addressesCondition ;
      owl:someValuesFrom ucm:Condition ] .

ucm:Report rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty ucm:hasStatement ;
      owl:allValuesFrom ucm:Statement ] .

#################################################################
# EXAMPLE SPECIALIZATIONS
#################################################################

ucm:HousingProvisioningProcess a owl:Class ;
    rdfs:label "housing provisioning process"@en ;
    rdfs:comment "An occurrent in which a dwelling is made available to a recipient."@en ;
    rdfs:subClassOf ucm:ProvisioningProcess ,
        [ a owl:Restriction ;
          owl:onProperty ucm:providesResource ;
          owl:someValuesFrom ucm:HousingUnit ] .

ucm:HousingAssignmentProcess a owl:Class ;
    rdfs:label "housing assignment process"@en ;
    rdfs:comment "An occurrent in which a person is designated to occupy or use a dwelling."@en ;
    rdfs:subClassOf ucm:ResourceAssignmentProcess ,
        [ a owl:Restriction ;
          owl:onProperty ucm:assignsResource ;
          owl:someValuesFrom ucm:HousingUnit ] .
